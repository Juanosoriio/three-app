# Backend Environment Variables
# Copia este archivo como .env y configura tus valores

# Puerto del servidor
PORT=5000

# MongoDB Atlas Connection String
# Reemplaza <user> y <password> con tus credenciales
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mythreeapp

# JWT Secret - Genera una clave segura
JWT_SECRET=tu_super_secret_key_aqui
